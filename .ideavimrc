"" Source your .vimrc
"source ~/.vimrc

"" -- Suggested options --
" Show a few lines of context around the cursor. Note that this makes the
" text scroll if you mouse-click near the start or end of the window.
set number "set line numbers
set relativenumber "set relative line numbers
set scrolloff=5
set incsearch "Do incremental searching.

map Q gq "Don't use Ex mode, use Q for formatting.

" Set single undo (IdeaVim) https://youtrack.jetbrains.com/issue/VIM-308/Undo-requires-one-more-step-if-the-cursor-is-not-at-the-position-where-it-was-after-undo
set nooldundo
" Use file navigation
set NERDTree

set mapleader = ' '
nmap <space> <Leader>

"" -- Map IDE actions to IdeaVim -- https://jb.gg/abva4t
"" Map \r to the Reformat Code action
"map \r <Action>(ReformatCode)

"" Map <leader>d to start debug
"map <leader>d <Action>(Debug)

nnoremap <C-d> <C-d>zz
nnoremap <C-u> <C-u>zz

map <leader>f <Action>(ReformatCode)
map <leader>e <Action>(ShowErrorDescription)
map grn <Action>(RenameElement)
map gra <Action>(ShowIntentionActions)
map grt <Action>(GotoTypeDeclaration)
map gri <Action>(GotoImplementation)
map grr <Action>(ShowUsages)
map gcc <Action>(CommentByLineComment)
map ]d <Action>(GotoNextError)
map [d <Action>(GotoPreviousError)
nmap [[ <Action>(MethodUp)
nmap ]] <Action>(MethodDown)
map <Tab> <Action>(NextTab)
map <S-Tab> <Action>(PreviousTab)
map <leader>x <Action>(CloseContent)

inoremap <c-k> <Up>
inoremap <c-j> <Down>

map <leader>sf <Action>(GotoFile)
map <leader>sw <Action>(SearchEverywhere)
map <leader>gb <Action>(Annotate)

map <A-h> <Action>(ActivateTerminalToolWindow)
"" Map \b to toggle the breakpoint on the current line
"map \b <Action>(ToggleLineBreakpoint)

" Find more examples here: https://jb.gg/share-ideavimrc
